msgid "monthly budget"
msgstr "бюджет на месяц"

#: financial_bot/handlers/adding_data.py:32
msgid "Enter your estimated monthly budget"
msgstr "Введите свой предполагаемый ежемесячный бюджет"

#: financial_bot/handlers/adding_data.py:35 financial_bot/keyboards/reply.py:21
msgid "limit expense"
